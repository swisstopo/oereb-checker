<?xml version="1.0" encoding="UTF-8"?>
<Configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns="https://logging.apache.org/xml/ns"
               xsi:schemaLocation="
                       https://logging.apache.org/xml/ns
                       https://logging.apache.org/xml/ns/log4j-config-2.xsd">

    <!-- Lambda config: console only (Lambda filesystem is read-only except /tmp) -->
    <!-- Activated via: mvn package -Plambda -->
    <Appenders>
        <Console name="LambdaConsole">
            <PatternLayout pattern="[%-5level] %d{yyyy-MM-dd HH:mm:ss.SSS} [%X{canton}] [%t] %c{1}:%L - %msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="org.verapdf" level="ERROR"/>
        <Root level="INFO">
            <AppenderRef ref="LambdaConsole"/>
        </Root>
    </Loggers>

</Configuration>
